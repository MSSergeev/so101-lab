# Virtual environment paths for SO-101 lab
# Copy to .env and fill in your paths

# Isaac Lab venv (used by: sim envs, RL training, eval scripts, teleop)
ISAACLAB_ENV=/path/to/IsaacLab/env_isaaclab

# LeRobot venv (used by: ACT/Diffusion/VLA training, reward labeling, IQL critics)
LEROBOT_ENV=/path/to/lerobot-env

# LeRobot source root (used by Isaac-env scripts that import lerobot directly)
LEROBOT_SRC=/path/to/lerobot/src

# Local tool venvs — created inside venvs/ (see venvs/README.md), no config needed here
# venvs/rerun  — Rerun visualizer for recorded episodes
# venvs/viewer — OpenCV live camera preview during recording
