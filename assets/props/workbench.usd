    defaultPrim = "Workbench"
    doc = "Black MDF tabletop (900x600x20mm) with 4 black metal legs (40x40x730mm)"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "Workbench" (
    kind = "component"
    prepend apiSchemas = ["PhysicsRigidBodyAPI"]
)
{
    uniform token physics:rigidBodyEnabled = "false"

    def Xform "Tabletop" (
        prepend apiSchemas = ["PhysicsMassAPI"]
    )
    {
        float physics:density = 630

        def Mesh "Visual"
        {
            float3[] extent = [(-0.45, -0.3, 0), (0.45, 0.3, 0.02)]
            int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
            int[] faceVertexIndices = [0, 1, 5, 4, 1, 2, 6, 5, 2, 3, 7, 6, 3, 0, 4, 7, 0, 3, 2, 1, 4, 5, 6, 7]
            rel material:binding = </Workbench/Materials/MDF_Black>
            point3f[] points = [(-0.45, -0.3, 0.73), (0.45, -0.3, 0.73), (0.45, 0.3, 0.73), (-0.45, 0.3, 0.73), (-0.45, -0.3, 0.75), (0.45, -0.3, 0.75), (0.45, 0.3, 0.75), (-0.45, 0.3, 0.75)]
            uniform token subdivisionScheme = "none"
        }

        def Cube "Collision" (
            prepend apiSchemas = ["PhysicsCollisionAPI", "PhysicsMeshCollisionAPI"]
        )
        {
            float3[] extent = [(-0.45, -0.3, -0.01), (0.45, 0.3, 0.01)]
            uniform token physics:approximation = "boundingCube"
            rel physics:material:binding = </Workbench/TablePhysicsMaterial>
            uniform token purpose = "guide"
            double size = 1
            double3 xformOp:scale = (0.9, 0.6, 0.02)
            double3 xformOp:translate = (0, 0, 0.74)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
    }

    def Xform "Leg_1" (
        prepend apiSchemas = ["PhysicsMassAPI"]
    )
    {
        float physics:density = 7850
        double3 xformOp:translate = (-0.41, -0.26, 0)
