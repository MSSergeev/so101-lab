        def Mesh "Visual"
        {
            float3[] extent = [(-0.02, -0.02, 0), (0.02, 0.02, 0.73)]
            int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
            int[] faceVertexIndices = [0, 1, 5, 4, 1, 2, 6, 5, 2, 3, 7, 6, 3, 0, 4, 7, 0, 3, 2, 1, 4, 5, 6, 7]
            rel material:binding = </Workbench/Materials/Metal_Black>
            point3f[] points = [(-0.02, -0.02, 0), (0.02, -0.02, 0), (0.02, 0.02, 0), (-0.02, 0.02, 0), (-0.02, -0.02, 0.73), (0.02, -0.02, 0.73), (0.02, 0.02, 0.73), (-0.02, 0.02, 0.73)]
